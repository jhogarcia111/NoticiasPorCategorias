# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# LinkedIn API Configuration
VITE_LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
VITE_LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here
VITE_LINKEDIN_REDIRECT_URI=https://yourdomain.com/auth/linkedin/callback

# News API Configuration
VITE_NEWSAPI_KEY=your_newsapi_key_here

# AI Services Configuration
VITE_DEEPSEEK_API_KEY=your_deepseek_api_key_here
VITE_STABILITY_API_KEY=your_stability_api_key_here

# App Configuration
VITE_APP_URL=https://yourdomain.com

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# SMTP Configuration (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# Supabase Service Role Key (for admin operations like password reset)
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here